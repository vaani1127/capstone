# HealthSaathi Terraform Variables Example
# Copy this file to terraform.tfvars and fill in your values

aws_region  = "us-east-1"
environment = "production"

# VPC Configuration
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# SSH Access - RESTRICT THIS IN PRODUCTION
ssh_allowed_ips = ["YOUR_IP_ADDRESS/32"]

# Database Configuration
db_instance_class    = "db.t3.medium"
db_allocated_storage = 100
db_name              = "healthsaathi"
db_username          = "postgres"
db_password          = "CHANGE_THIS_SECURE_PASSWORD"

# Application Configuration
ami_id        = "ami-0c55b159cbfafe1f0"  # Ubuntu 22.04 LTS - Update for your region
instance_type = "t3.medium"
key_pair_name = "your-key-pair-name"
jwt_secret_key = "GENERATE_SECURE_RANDOM_KEY_MIN_32_CHARS"

# Auto Scaling
asg_min_size         = 2
asg_max_size         = 10
asg_desired_capacity = 2

# SSL Certificate
ssl_certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERTIFICATE_ID"
