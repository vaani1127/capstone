# HealthSaathi Production Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Configuration
# ============================================
PROJECT_NAME=HealthSaathi API
VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# Database Configuration
# ============================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:CHANGE_PASSWORD@db-host:5432/healthsaathi

# Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================
# JWT Configuration
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GENERATE_SECURE_RANDOM_KEY_MINIMUM_32_CHARACTERS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/healthsaathi/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ============================================
# Redis Configuration (Optional)
# ============================================
# For WebSocket scaling and caching
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@yourdomain.com
SMTP_TLS=true

# ============================================
# Security Configuration
# ============================================
# Password hashing rounds (bcrypt)
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================
# Monitoring Configuration (Optional)
# ============================================
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# ============================================
# Backup Configuration
# ============================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
S3_BACKUP_BUCKET=healthsaathi-backups
S3_BACKUP_PREFIX=production

# ============================================
# Feature Flags
# ============================================
ENABLE_WEBSOCKET=true
ENABLE_AUDIT_LOGGING=true
ENABLE_BLOCKCHAIN_VERIFICATION=true
